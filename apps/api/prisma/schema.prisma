generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Archetype {
  botan
  sportsman
  partygoer
}

enum ProfileEventType {
  profile_created
  archetype_selected
  action_performed
  project_contributed
  project_unlocked
  benefit_claimed
  contribution_liked
  reputation_gained
  exam_completed
}

enum PartyStatus {
  queueing
  ready_check
  completed
  cancelled
}

enum ExamOutcome {
  success
  partial_failure
}

enum ProjectKind {
  notes
  gym
  festival
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  telegramId   BigInt    @unique
  firstName    String
  lastName     String?
  username     String?
  languageCode String?
  photoUrl     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  profile      Profile?

  @@map("users")
}

model Profile {
  userId          String      @id @db.Uuid
  archetype       Archetype?
  level           Int         @default(1)
  profileXp       Int         @default(0)
  archetypeXp     Int         @default(0)
  energy          Int         @default(3)
  softCurrency    Int         @default(0)
  reputation      Int         @default(0)
  energyUpdatedAt DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  events          ProfileEvent[]
  contributions   Contribution[]
  benefitClaims   BenefitClaim[]
  partyMembers    PartyMember[]
  examRewards     ExamReward[]
  ownedParties     Party[]      @relation("PartyOwner")

  @@map("profiles")
}

model ProfileEvent {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @db.Uuid
  eventType  ProfileEventType
  payload    Json
  createdAt  DateTime         @default(now())
  profile    Profile          @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("profile_events")
}

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  kind        ProjectKind   @unique
  title       String
  description String
  threshold   Int
  progress    Int           @default(0)
  affinity    Archetype?
  unlockedAt  DateTime?
  unlockCycle Int           @default(1)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  contributions Contribution[]
  benefitClaims BenefitClaim[]

  @@map("projects")
}

model Contribution {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  userId    String   @db.Uuid
  actionId  String
  amount    Int
  requestId String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  profile   Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  likes     ContributionLike[]

  @@unique([userId, requestId])
  @@index([projectId, createdAt])
  @@index([userId, createdAt])
  @@map("contributions")
}

model BenefitClaim {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  userId      String   @db.Uuid
  unlockCycle Int      @default(1)
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  profile     Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([projectId, userId, unlockCycle])
  @@map("benefit_claims")
}

model ContributionLike {
  id             String       @id @default(uuid()) @db.Uuid
  contributionId String       @db.Uuid
  fromUserId     String       @db.Uuid
  createdAt      DateTime     @default(now())
  contribution   Contribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)

  @@unique([contributionId, fromUserId])
  @@map("contribution_likes")
}

model Party {
  id          String       @id @default(uuid()) @db.Uuid
  ownerUserId String       @db.Uuid
  capacity    Int
  status      PartyStatus  @default(queueing)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  owner       Profile      @relation("PartyOwner", fields: [ownerUserId], references: [userId], onDelete: Cascade)
  members     PartyMember[]
  run         ExamRun?

  @@index([status, capacity, createdAt])
  @@map("parties")
}

model PartyMember {
  id                String    @id @default(uuid()) @db.Uuid
  partyId           String    @db.Uuid
  userId            String    @db.Uuid
  archetypeSnapshot Archetype
  joinedAt          DateTime  @default(now())
  readyAt           DateTime?
  party             Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)
  profile           Profile   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([partyId, userId])
  @@index([userId])
  @@index([partyId, joinedAt])
  @@map("party_members")
}

model ExamRun {
  id               String       @id @default(uuid()) @db.Uuid
  partyId          String       @unique @db.Uuid
  resolvedByUserId String       @db.Uuid
  seed             String
  successChancePct Int
  rollPct          Int
  outcome          ExamOutcome
  summary          String
  resolvedAt       DateTime     @default(now())
  party            Party        @relation(fields: [partyId], references: [id], onDelete: Cascade)
  rewards          ExamReward[]

  @@index([resolvedAt])
  @@map("exam_runs")
}

model ExamReward {
  id           String   @id @default(uuid()) @db.Uuid
  examRunId    String   @db.Uuid
  userId       String   @db.Uuid
  profileXp    Int
  archetypeXp  Int
  softCurrency Int
  reputation   Int
  createdAt    DateTime @default(now())
  run          ExamRun  @relation(fields: [examRunId], references: [id], onDelete: Cascade)
  profile      Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([examRunId, userId])
  @@index([userId, createdAt])
  @@map("exam_rewards")
}
